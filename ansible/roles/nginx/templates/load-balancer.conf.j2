upstream backends {
{% for port in apache_ports %}
    server 127.0.0.1:{{ port }};
{% endfor %}
}

server {
    listen {{ nginx_port }};
    server_name _;

    location / {
        proxy_pass http://backends;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /stub_status {
        stub_status on;
        allow 127.0.0.1;
        deny all;
    }
}
